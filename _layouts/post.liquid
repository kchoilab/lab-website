---
layout: default
---
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-10">
      <div class="card" style="border-radius: 20px; border: 1px solid #e0e0e0; box-shadow: 0 4px 15px rgba(0,0,0,0.05); overflow: hidden;">
        
        <div class="card-body p-5">
          <div class="d-flex align-items-center mb-4">
            <div class="rounded-circle bg-light d-flex justify-content-center align-items-center" style="width: 45px; height: 45px; border: 1px solid #ddd;">
              <span style="font-size: 1rem; color: #666;">{{ page.author | default: "K" | slice: 0 }}</span>
            </div>
            <div class="ml-3">
              <h5 class="mb-0" style="font-weight: 700;">{{ page.author | default: "Kiri Choi" }}</h5>
              <p class="text-muted mb-0" style="font-size: 0.9rem;">{{ page.date | date: "%Y년 %m월 %d일" }}</p>
            </div>
          </div>

          <hr style="border-top: 1px solid #eee; margin: 20px 0;">

          <h1 class="post-title" style="font-weight: 800; margin-bottom: 30px;">{{ page.title }}</h1>

          <div class="post-content" style="line-height: 1.8; font-size: 1.1rem; color: #333;">
            {{ content }}
          </div>
          
          <div class="mt-5">
            <a href="{{ '/blog/' | relative_url }}" class="btn btn-outline-secondary btn-sm" style="border-radius: 20px;">← Back to Blog</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>